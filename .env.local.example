# ============================================
# COPY THIS FILE AND RENAME TO: .env.local
# Then fill in your real values below
# ============================================

# MongoDB Atlas connection string
# Get this from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.XXXXX.mongodb.net/?retryWrites=true&w=majority

# Google Gemini API Key (FREE - no credit card needed)
# Get this from: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
